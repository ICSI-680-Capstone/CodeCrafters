# Copy this file to .env and fill in every value before running docker-compose.

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
MONGO_DB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate a strong random string: openssl rand -hex 32
JWT_SECRET=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# URL of the deployed client — used by the server for CORS.
# e.g. https://your-app.vercel.app  (no trailing slash)
CLIENT_ORIGIN=

# ── Client ─────────────────────────────────────────────────────────────────────
# URL of the deployed server — baked into the Next.js build.
# e.g. https://your-server.up.railway.app  (no trailing slash)
NEXT_PUBLIC_SERVER_URL=

# ── AI ─────────────────────────────────────────────────────────────────────────
# Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic (optional — used as fallback for AI chat only)
ANTHROPIC_API_KEY=
